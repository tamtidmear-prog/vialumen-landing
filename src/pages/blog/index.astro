---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="Blog — ViaLumen ⭐" description="บันทึกการเรียนรู้จาก Oracle School workshops">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl font-bold gradient-text mb-2">Blog</h1>
    <p class="text-slate-400 mb-12 font-[Sarabun]">บันทึกการเรียนรู้จาก Oracle School</p>

    <div class="space-y-6">
      {posts.map((post) => (
        <article class="glass rounded-xl p-6 hover:bg-white/10 transition">
          <div class="flex items-center gap-3 mb-2">
            {post.data.workshop && (
              <span class="text-xs px-2 py-1 rounded-full bg-indigo-500/20 text-indigo-300 font-mono">
                {post.data.workshop}
              </span>
            )}
            <span class="text-xs text-slate-500">{post.data.date}</span>
          </div>
          <h2 class="text-xl font-bold text-white mb-1">{post.data.title}</h2>
          <h3 class="text-base text-slate-400 mb-3 font-[Sarabun]">{post.data.titleTH}</h3>
          <p class="text-sm text-slate-400">{post.data.description}</p>
          <p class="text-sm text-slate-500 font-[Sarabun]">{post.data.descriptionTH}</p>
          <div class="flex gap-2 mt-3">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs text-slate-500 bg-white/5 px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>
